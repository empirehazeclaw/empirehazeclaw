#!/bin/bash
# Text-to-Voice - Convert text to speech using Edge TTS (Microsoft)
# Usage: text-to-voice "Your text here" [output-file] [voice]
#
# Voices (German):
#   de-DE-SeraphinaMultilingualNeural (Female) - Recommended
#   de-DE-FlorianMultilingualNeural (Male)
#   de-DE-KatjaNeural (Female)
#   de-DE-KillianNeural (Male)
#
# Examples:
#   text-to-voice "Hallo Welt!" greeting.mp3
#   text-to-voice "Guten Morgen!" morning.mp3 de-DE-FlorianMultilingualNeural

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

EDGE_TTS="/home/clawbot/.local/bin/edge-tts"

usage() {
    echo "🔊 Text-to-Voice (Edge TTS)"
    echo ""
    echo "Usage: $0 \"<text>\" [output-file] [voice]"
    echo ""
    echo "Arguments:"
    echo "  text          Text to synthesize (in quotes)"
    echo "  output-file   Optional, default=output.mp3"
    echo "  voice         Optional, default=de-DE-SeraphinaMultilingualNeural"
    echo ""
    echo "German Voices:"
    echo "  de-DE-SeraphinaMultilingualNeural (Female) - Recommended"
    echo "  de-DE-FlorianMultilingualNeural (Male)"
    echo "  de-DE-KatjaNeural (Female)"
    echo "  de-DE-KillianNeural (Male)"
    echo ""
    echo "Examples:"
    echo "  $0 \"Hallo Welt!\""
    echo "  $0 \"Hallo!\" greeting.mp3"
    echo "  $0 \"Guten Morgen!\" morning.mp3 de-DE-FlorianMultilingualNeural"
    exit 1
}

if [ -z "$1" ]; then
    usage
fi

TEXT="$1"
OUTPUT="${2:-output.mp3}"
VOICE="${3:-de-DE-SeraphinaMultilingualNeural}"

# Check if edge-tts is installed
if [ ! -f "$EDGE_TTS" ]; then
    echo -e "${RED}❌ Error: edge-tts not found at $EDGE_TTS${NC}"
    exit 1
fi

echo -e "${YELLOW}🔊 Generating speech with Edge TTS...${NC}"
echo -e "${YELLOW}📝 Text: $TEXT${NC}"
echo -e "${YELLOW}🎤 Voice: $VOICE${NC}"
echo -e "${YELLOW}📁 Output: $OUTPUT${NC}"

# Generate speech
if edge-tts -t "$TEXT" -v "$VOICE" --write-media "$OUTPUT" 2>&1; then
    if [ -f "$OUTPUT" ] && [ -s "$OUTPUT" ]; then
        echo ""
        echo -e "${GREEN}✅ Speech generation complete!${NC}"
        echo -e "${GREEN}📁 File: $OUTPUT ($(ls -lh "$OUTPUT" | awk '{print $5}'))${NC}"
        echo ""
        echo "▶️  Play with: ffplay $OUTPUT"
    fi
else
    echo -e "${RED}❌ Error: Failed to generate speech${NC}"
    exit 1
fi