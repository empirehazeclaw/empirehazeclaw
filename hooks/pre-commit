#!/bin/bash
# Pre-commit hook to prevent API key exposure
# Created: 2026-04-12 after security incident

echo "🔍 Checking for API keys in staged files..."

# Patterns that should NEVER be committed
PATTERNS=(
  "sk-or-v1-[a-zA-Z0-9]\{40,\}"
  "sk-proj-[a-zA-Z0-9_-]\{50,\}"
  "hf_[a-zA-Z0-9]\{20,\}"
  "ghp_[a-zA-Z0-9]\{30,\}"
  "ak-[A-Za-z0-9]\{16,\}:as-"
  "AIza[a-zA-Z0-9_-]\{30,\}"
  "sk-ant-api03-[a-zA-Z0-9_-]\{50,\}"
)

FOUND=0

for pattern in "${PATTERNS[@]}"; do
  if git diff --cached --name-only | xargs -I {} sh -c "grep -qE '$pattern' '{}' 2>/dev/null && echo '{}'"; then
    echo "❌ BLOCKED: API key pattern detected!"
    FOUND=1
  fi
done

if [ $FOUND -eq 1 ]; then
  echo ""
  echo "🚨 Remove API keys before committing!"
  echo "📖 See: ceo/docs/SECURITY_INCIDENT_2026-04-12.md"
  exit 1
fi

echo "✅ No API keys detected - commit allowed"
