{
  "version": "1.0",
  "lastUpdated": "2026-04-08",
  "principle": "Least Privilege — Jeder Agent erhält nur die minimal notwendigen Rechte",

  "agents": {
    "ceo": {
      "role": "Chief Executive Officer / SOVEREIGN Orchestrator",
      "workspaces": ["ceo", "uni-*"],
      "tools": ["*"],
      "permissions": ["read", "write", "delegate", "audit", "manage"],
      "canDelegateTo": ["security", "data", "builder", "qc", "research"],
      "restrictions": [],
      "description": "CEO behält Admin-Rechte für Delegation und Orchestrierung"
    },

    "security": {
      "role": "Security Officer",
      "workspaces": ["security", "logs"],
      "tools": ["read", "write", "exec", "web_fetch", "web_search"],
      "permissions": ["read", "write", "audit", "execute"],
      "canDelegateTo": [],
      "restrictions": [
        "darf keine Dateien in anderen Workspaces ändern",
        "darf keine exec-Befehle mit Systemänderungen ausführen",
        "darf keine Systemkonfigurationen ändern"
      ],
      "description": "Security Officer braucht Lese-Zugriff auf alle Logs für Audits",
      "execAllowedDirectories": ["/home/clawbot/.openclaw/workspace/security/"]
    },

    "data": {
      "role": "Data Manager (CDO)",
      "workspaces": ["data", "memory"],
      "tools": ["read", "write", "exec", "edit"],
      "permissions": ["read", "write", "manage"],
      "canDelegateTo": [],
      "restrictions": [
        "darf keine Sicherheits-relevanten Konfigurationen ändern",
        "darf keine exec-Befehle mit Systemänderungen ausführen"
      ],
      "description": "Data Manager verwaltet Memory, DB, Indexierung & Historie"
    },

    "builder": {
      "role": "Builder / Developer",
      "workspaces": ["builder", "scripts", "skills"],
      "tools": ["read", "write", "edit", "exec"],
      "permissions": ["read", "write", "execute"],
      "canDelegateTo": [],
      "restrictions": [
        "darf nicht auf security-Workspace schreiben",
        "darf nicht auf ceo-Workspace schreiben",
        "darf keine System-Sicherheitskonfigurationen ändern",
        "exec nur für Script-Ausführung in /home/clawbot/.openclaw/workspace/scripts/"
      ],
      "description": "Builder braucht exec für Script-Ausführung, aber keine Admin-Rechte",
      "execAllowedDirectories": ["/home/clawbot/.openclaw/workspace/scripts/"]
    },

    "qc": {
      "role": "QC Officer / Quality Controller",
      "workspaces": ["qc"],
      "tools": ["read", "write"],
      "permissions": ["read", "write", "audit"],
      "canDelegateTo": [],
      "restrictions": [
        "darf keine Dateien in anderen Workspaces ändern",
        "darf keine exec-Befehle ausführen"
      ],
      "description": "QC Officer validiert Ergebnisse, braucht nur Lese-/Schreibzugriff"
    },

    "research": {
      "role": "Research Analyst",
      "workspaces": ["research"],
      "tools": ["read", "write", "web_search", "web_fetch"],
      "permissions": ["read", "write", "web_search", "web_fetch"],
      "canDelegateTo": [],
      "restrictions": [
        "darf keine Dateien in anderen Workspaces ändern",
        "darf keine exec-Befehle ausführen"
      ],
      "description": "Research Agent für Internet-Recherchen, braucht Web-Zugriff"
    },

    "uni-curriculum": {
      "role": "University Curriculum Agent",
      "workspaces": ["uni-curriculum"],
      "tools": ["read", "write", "edit"],
      "permissions": ["read", "write"],
      "canDelegateTo": [],
      "restrictions": [
        "nur Zugriff auf eigenen Workspace",
        "darf keine exec-Befehle ausführen"
      ],
      "description": "Uni-Curriculum: Verwaltet Curricula-Dokumente"
    },

    "uni-examiner": {
      "role": "University Examiner Agent",
      "workspaces": ["uni-examiner"],
      "tools": ["read", "write", "edit"],
      "permissions": ["read", "write"],
      "canDelegateTo": [],
      "restrictions": [
        "nur Zugriff auf eigenen Workspace",
        "darf keine exec-Befehle ausführen"
      ],
      "description": "Uni-Examiner: Verwaltet Prüfungsdokumente"
    },

    "uni-research": {
      "role": "University Research Agent",
      "workspaces": ["uni-research"],
      "tools": ["read", "write", "web_search", "web_fetch"],
      "permissions": ["read", "write", "search"],
      "canDelegateTo": [],
      "restrictions": [
        "nur Zugriff auf eigenen Workspace",
        "darf keine System-exec-Befehle ausführen"
      ],
      "description": "Uni-Research: Recherchiert für Uni-Projekte"
    }
  },

  "workspace_ownership": {
    "ceo": ["ceo"],
    "security": ["security", "logs"],
    "data": ["data", "memory"],
    "builder": ["builder", "scripts", "skills"],
    "qc": ["qc"],
    "research": ["research"],
    "uni-curriculum": ["uni-curriculum"],
    "uni-examiner": ["uni-examiner"],
    "uni-research": ["uni-research"]
  },

  "cross_workspace_access": {
    "security": {
      "canRead": ["logs", "memory", "data"],
      "description": "Security Officer braucht Lese-Zugriff auf alle Logs für Audits"
    },
    "ceo": {
      "canRead": ["*"],
      "canWrite": ["ceo", "uni-*"],
      "description": "CEO hat Zugriff auf alle Workspaces für Orchestrierung"
    },
    "data": {
      "canRead": ["memory"],
      "description": "Data Manager liest Memory für Indexierung"
    }
  }
}
