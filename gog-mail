#!/bin/bash
# Source or refresh token
TOKEN_FILE="/home/clawbot/.config/gogcli/token.env"

# Check if token exists and is fresh (less than 1 hour old)
if [ -f "$TOKEN_FILE" ]; then
    FILE_AGE=$(($(date +%s) - $(stat -c %Y "$TOKEN_FILE" 2>/dev/null || echo 0)))
    if [ "$FILE_AGE" -gt 3500 ]; then
        # Token is older than ~1 hour, refresh it
        python3 /home/clawbot/.openclaw/workspace/scripts/gog-refresh-token.py
    fi
    source "$TOKEN_FILE"
fi

# If no token, refresh
if [ -z "$GOG_ACCESS_TOKEN" ]; then
    python3 /home/clawbot/.openclaw/workspace/scripts/gog-refresh-token.py
    source "$TOKEN_FILE"
fi

# Run gog with the token
export GOG_ACCESS_TOKEN
exec /home/clawbot/.linuxbrew/bin/gog "$@"
