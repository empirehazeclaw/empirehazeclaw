#!/usr/bin/env python3
"""Quick memory search command"""
import sys
sys.path.insert(0, 'scripts')
from memory_db import search_memory, get_priority

query = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else "main"

if query == "p1":
    print("🔴 P1 Items:")
    for item in get_priority("P1"):
        print(f"  {item[:150]}...")
elif query == "p2":
    print("🟡 P2 Items:")
    for item in get_priority("P2"):
        print(f"  {item[:150]}...")
elif query == "p3":
    print("🟢 P3 Items:")
    for item in get_priority("P3"):
        print(f"  {item[:150]}...")
else:
    print(f"🔍 Searching for: '{query}'")
    results = search_memory(query)
    for r in results:
        print(f"\n[{r['priority']}] {r['content'][:200]}...")
