# AI Trading Bot V2 - Environment Variables
# Kopiere diese Datei nach .env und fülle deine Werte aus

# ====================
# API KEYS
# ====================

# Binance API Keys (https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-4b9c0e6c5d2d4c2c9c2c0c9c9c2c0c9c)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_key_here

# Discord Webhook (optional - für Alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url

# ====================
# MODUS
# ====================

# Trading Modus: SIGNAL, DCA, GRID, BACKTEST
TRADING_MODE=SIGNAL

# ====================
# TRADING PARAMETER
# ====================

# Symbole (Komma-getrennt)
SYMBOLS=BTC/USDT,ETH/USDT

# USDT pro Trade
TRADE_AMOUNT=10

# DCA Settings
DCA_MULTIPLIER=1.5
DCA_MAX_LEVELS=3

# Grid Settings
GRID_SPACING=2
GRID_LEVELS=5

# ====================
# RISK MANAGEMENT
# ====================

# Stop Loss & Take Profit (%)
STOP_LOSS=10
TAKE_PROFIT=5

# Trailing Stop (%)
TRAILING_STOP_PCT=2.0

# Risk per Trade (%)
RISK_PER_TRADE_PCT=2.0

# Max offene Positionen
MAX_OPEN_POSITIONS=3

# Max Drawdown - Bot stoppt bei Erreichen (%)
MAX_DRAWDOWN_PCT=20

# Position Sizing nutzen (true/false)
USE_POSITION_SIZING=true

# ====================
# BACKTEST
# ====================

BACKTEST_START=2025-01-01
BACKTEST_END=2025-12-31
INITIAL_CAPITAL=1000

# ====================
# TEST MODUS
# ====================

# Dry Run - keine echten Trades! (true/false)
DRY_RUN=true

# Check Interval (Sekunden)
CHECK_INTERVAL=300
